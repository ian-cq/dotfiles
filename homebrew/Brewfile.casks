# cask "rectangle"                # window management
# cask "obsidian"
# cask "zed"
# cask "openlens"                 # Kubernetes GUI
# cask "spotify"
# cask "telegram"
# cask "whatsapp"
# cask "twingate"                 # zero-trust VPN client
