#!/bin/bash
#
# Bootstrap installer for ian-cq/dotfiles.
#
# Usage:
#   zsh -c "$(curl -fsSL https://raw.githubusercontent.com/ian-cq/dotfiles/refs/heads/main/install)"
#   ./install --version v1.2.3
#
set -euo pipefail

repository_owner="ian-cq"
repository_name="dotfiles"
version=""

# ---------------------------------------------------------------------------
# Args
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --version)
      version="${2:-}"
      [[ -z "$version" ]] && { echo "[ERROR] --version requires a value" >&2; exit 1; }
      shift 2
      ;;
    -h|--help)
      sed -n '2,9p' "$0"; exit 0
      ;;
    *)
      echo "[WARN] Unknown argument: $1" >&2
      shift
      ;;
  esac
done

if [[ -z "$version" ]]; then
  echo "[INFO] No --version given; resolving latest release..."
  version=$(curl --silent "https://api.github.com/repos/${repository_owner}/${repository_name}/releases/latest" \
            | awk -F '"' '/"tag_name"/ {print $4}')
  [[ -z "$version" ]] && { echo "[ERROR] Could not resolve latest version" >&2; exit 1; }
  echo "[INFO] Latest version: ${version}"
fi

# ---------------------------------------------------------------------------
# Detect platform
# ---------------------------------------------------------------------------
os=$(uname -s | tr '[:upper:]' '[:lower:]')
arch=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/')

base_url="https://github.com/${repository_owner}/${repository_name}"
binary="setup_quanianitis-${version}-${os}-${arch}.tar.gz"
source_code="${version}.tar.gz"

# ---------------------------------------------------------------------------
# Install prerequisites (Linux only)
# ---------------------------------------------------------------------------
if [[ "$os" == "linux" ]]; then
  echo "[INFO] Installing prerequisites for Linux..."
  sudo apt install -y build-essential procps curl file git
fi

# ---------------------------------------------------------------------------
# Download artefacts
# ---------------------------------------------------------------------------
echo "[INFO] Downloading binary and source for ${version}..."
curl -fsSL -O "${base_url}/releases/download/${version}/${binary}"
curl -fsSL -O "${base_url}/archive/refs/tags/${source_code}"

if [[ -d "$HOME/dotfiles" ]]; then
  echo "[INFO] $HOME/dotfiles already exists; skipping clone."
else
  git clone --branch "${version}" "${base_url}.git" "$HOME/dotfiles"
fi

tar -xzf "${binary}"
tar -xzf "${source_code}"

# ---------------------------------------------------------------------------
# Install
# ---------------------------------------------------------------------------
echo "[INFO] Archiving downloaded artefacts to ~/archives ..."
mkdir -p "$HOME/archives"
mv "dotfiles-${version#v}" "${binary}" "${source_code}" "$HOME/archives" 2>/dev/null || \
  mv "dotfiles-${version}" "${binary}" "${source_code}" "$HOME/archives"

install_dir="/usr/local/bin"
[[ -d /opt/homebrew/bin ]] && install_dir="/opt/homebrew/bin"
echo "[INFO] Installing setup_quanianitis to ${install_dir}..."
sudo mv ./setup_quanianitis "${install_dir}/setup_quanianitis"

echo "[INFO] Running setup_quanianitis..."
cd "$HOME/dotfiles" && "${install_dir}/setup_quanianitis"

echo "[INFO] Done!"
