#!/usr/bin/env bash
#
# Bootstrap installer for ian-cq/dotfiles (run #2 of 2).
#
# Run scripts/prereqs.sh FIRST — it installs the base toolchain (git, curl,
# stow, zsh, a C toolchain and Homebrew). This script downloads the prebuilt
# setup_quanianitis binary (or builds it from source if no release matches),
# clones the repo and runs the installer, which creates every symlink and
# installs the Brewfile.
#
# Usage:
#   ./scripts/prereqs.sh                # run #1: base deps + Homebrew
#   ./install                           # run #2: download + run installer
#   ./install --version v1.2.3          # pin a specific release
#
set -euo pipefail

repository_owner="ian-cq"
repository_name="dotfiles"
version=""

log()  { printf '[install] %s\n' "$*"; }
warn() { printf '[install][WARN] %s\n' "$*" >&2; }
die()  { printf '[install][ERROR] %s\n' "$*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

# ---------------------------------------------------------------------------
# Args
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --version)
      version="${2:-}"
      [[ -z "$version" ]] && die "--version requires a value"
      shift 2
      ;;
    -h|--help)
      sed -n '2,13p' "$0"; exit 0
      ;;
    *)
      warn "Unknown argument: $1"
      shift
      ;;
  esac
done

# ---------------------------------------------------------------------------
# Prerequisite check — prereqs.sh must have run first
# ---------------------------------------------------------------------------
missing=()
for tool in curl git stow; do
  have "$tool" || missing+=("$tool")
done
if [[ ${#missing[@]} -gt 0 ]]; then
  die "Missing prerequisites: ${missing[*]}. Run ./scripts/prereqs.sh first."
fi

# sudo only when needed and available.
SUDO=""
if [[ "${EUID:-$(id -u)}" -ne 0 ]] && have sudo; then
  SUDO="sudo"
fi

# ---------------------------------------------------------------------------
# Detect platform
# ---------------------------------------------------------------------------
os=$(uname -s | tr '[:upper:]' '[:lower:]')
arch=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/')

base_url="https://github.com/${repository_owner}/${repository_name}"

# ---------------------------------------------------------------------------
# Resolve version (latest release unless pinned)
# ---------------------------------------------------------------------------
if [[ -z "$version" && -z "${FORCE_SOURCE_BUILD:-}" ]]; then
  log "No --version given; resolving latest release…"
  version=$(curl --silent "https://api.github.com/repos/${repository_owner}/${repository_name}/releases/latest" \
            | awk -F '"' '/"tag_name"/ {print $4}')
  if [[ -z "$version" ]]; then
    warn "Could not resolve a latest release (none published yet?)."
  else
    log "Latest version: ${version}"
  fi
fi

# ---------------------------------------------------------------------------
# Clone the repo (with submodules, best-effort) if not already present
# ---------------------------------------------------------------------------
if [[ -d "$HOME/dotfiles/.git" ]]; then
  log "$HOME/dotfiles already exists; skipping clone."
else
  log "Cloning repository to ~/dotfiles…"
  if [[ -n "$version" ]]; then
    git clone --branch "${version}" --recurse-submodules "${base_url}.git" "$HOME/dotfiles" \
      || git clone --branch "${version}" "${base_url}.git" "$HOME/dotfiles"
  else
    git clone --recurse-submodules "${base_url}.git" "$HOME/dotfiles" \
      || git clone "${base_url}.git" "$HOME/dotfiles"
  fi
fi

# ---------------------------------------------------------------------------
# Obtain the setup_quanianitis binary.
# Prefer a prebuilt release; fall back to building from source with `go`.
# ---------------------------------------------------------------------------
workdir="$(mktemp -d)"
trap 'rm -rf "$workdir"' EXIT
binary_path=""

# FORCE_SOURCE_BUILD=1 skips the release download and builds from the local
# working tree — used when testing local changes that aren't yet released.
if [[ -n "${FORCE_SOURCE_BUILD:-}" && "${FORCE_SOURCE_BUILD}" != "0" ]]; then
  version=""
  log "FORCE_SOURCE_BUILD set — building from local source instead of a release."
fi

if [[ -n "$version" ]]; then
  binary="setup_quanianitis-${version}-${os}-${arch}.tar.gz"
  log "Downloading prebuilt binary ${binary}…"
  if curl -fsSL -o "${workdir}/${binary}" "${base_url}/releases/download/${version}/${binary}"; then
    tar -xzf "${workdir}/${binary}" -C "${workdir}"
    [[ -f "${workdir}/setup_quanianitis" ]] && binary_path="${workdir}/setup_quanianitis"

    # Keep a copy of the release artefact for reference.
    mkdir -p "$HOME/archives"
    cp "${workdir}/${binary}" "$HOME/archives/" 2>/dev/null || true
  else
    warn "Release binary not available for ${version}/${os}/${arch}."
  fi
fi

if [[ -z "$binary_path" ]]; then
  have go || die "No prebuilt binary and 'go' is not installed. Install Go (brew install go) or run scripts/prereqs.sh, then retry."
  log "Building setup_quanianitis from source with go…"
  ( cd "$HOME/dotfiles" && go build -o "${workdir}/setup_quanianitis" . )
  binary_path="${workdir}/setup_quanianitis"
fi

# ---------------------------------------------------------------------------
# Install the binary onto PATH
# ---------------------------------------------------------------------------
install_dir="/usr/local/bin"
for candidate in /opt/homebrew/bin /home/linuxbrew/.linuxbrew/bin; do
  [[ -d "$candidate" ]] && { install_dir="$candidate"; break; }
done
log "Installing setup_quanianitis to ${install_dir}…"
if [[ -w "$install_dir" ]]; then
  install -m 0755 "$binary_path" "${install_dir}/setup_quanianitis"
else
  $SUDO install -m 0755 "$binary_path" "${install_dir}/setup_quanianitis"
fi

# ---------------------------------------------------------------------------
# Run the installer
# ---------------------------------------------------------------------------
log "Running setup_quanianitis…"
cd "$HOME/dotfiles" && "${install_dir}/setup_quanianitis"

log "Done! Open a new terminal (or run: exec zsh -l) to pick up your shell."
