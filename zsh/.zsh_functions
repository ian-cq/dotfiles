# Kubectl context helpers (POWERLEVEL9K_* vars are no-ops if p10k isn't loaded)

function kubeon() {
  kube-toggle
  if [[ -z "$(kubectl config current-context 2>/dev/null)" ]]; then
    kubectx
  fi
  kube-toggle
}

function kube-toggle() {
  if (( ${+POWERLEVEL9K_KUBECONTEXT_SHOW_ON_COMMAND} )); then
    unset POWERLEVEL9K_KUBECONTEXT_SHOW_ON_COMMAND
  else
    POWERLEVEL9K_KUBECONTEXT_SHOW_ON_COMMAND='kubectl|helm|kubens'
  fi
  command -v p10k >/dev/null && p10k reload
  if zle; then
    zle push-input
    zle accept-line
  fi
}
